{
  "name": "ssd-cloud-storage",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client run dev",
    "build": "npm --prefix client run build",
    "test": "npm --prefix server run test",
    "deploy:pages-root": "npm --prefix client run build && rsync -a --delete client/dist/assets/ assets/ && cp client/dist/index.html index.html && touch .nojekyll"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8"
  }
}
